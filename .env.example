# Database Configuration (Local)
DATABASE_URL=postgresql://user:password@db:5432/rlhf

# === CLOUD DEPLOYMENT ===
# 1. Neon.tech (Free Cloud Postgres) — replace DATABASE_URL above with:
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/rlhf?sslmode=require

# 2. Render/Koyeb (Backend)
# Set DATABASE_URL on Render dashboard from the Neon connection string.

# 3. Vercel (Frontend)
# Add this env var in Vercel dashboard:
# VITE_API_URL=https://your-render-app.onrender.com

# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

# Service URLs (used by docker-compose locally)
BACKEND_URL=http://backend:8000
SANDBOX_URL=http://sandbox:8001

# Frontend Configuration
VITE_API_URL=http://localhost:8000
